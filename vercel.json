{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    },
    {
      "src": "*.ico",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/marketing",
      "dest": "/marketing.html"
    },
    {
      "src": "/bootcamp",
      "dest": "/bootcamp.html"
    },
    {
      "src": "/hackathon",
      "dest": "/hackathon.html"
    },
    {
      "src": "/recommend",
      "dest": "/recommend.html"
    },
    {
      "src": "/partnership",
      "dest": "/partnership.html"
    },
    {
      "src": "/tournament",
      "dest": "/tournament.html"
    },
    {
      "src": "/tournament/top10",
      "dest": "/tournament-top10.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
